{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NeuralNotes",
  "version": "0.1.0",
  "identifier": "app.neuralnotes.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5177",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NeuralNotes",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 680,
        "transparent": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": []
    }
  }
}
